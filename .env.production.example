# ═══════════════════════════════════════════════════════════════════════════════
# Vercel Environment Variables (Add these in Vercel Dashboard → Settings → Environment Variables)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Supabase Database - Transaction/Pooler mode (Prisma Client queries)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1

# Supabase Database - Session mode (Prisma Migrate)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-PROJECT-REF].supabase.co:5432/postgres

# NextAuth Configuration
NEXTAUTH_URL=https://leadflow.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl

# Anthropic AI API Key (Required for AI features)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── OPTIONAL (Feature-specific) ───────────────────────────────────────────────

# Email Services
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SENDGRID_API_KEY=

# Email Verification
ZEROBOUNCE_API_KEY=
HUNTER_API_KEY=

# Lead Enrichment
APOLLO_API_KEY=
CLEARBIT_API_KEY=

# Social Media APIs
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Calendar Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CALENDLY_API_KEY=

# Search
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Queue
REDIS_URL=

# Analytics
POSTHOG_API_KEY=
POSTHOG_HOST=

# App URL
NEXT_PUBLIC_APP_URL=https://leadflow.vercel.app
NODE_ENV=production
